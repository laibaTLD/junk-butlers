# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Template Configuration
NEXT_PUBLIC_TEMPLATE_ID=premium-corporate-template
NEXT_PUBLIC_ID=c0f6f1c7-82d2-4410-92ab-26d6071d5c3c

# API Configuration (for production, use your deployed URL)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Production API URL (uncomment and set for production)
# NEXT_PUBLIC_API_URL=https://your-domain.com

# ISR Revalidation Secret (generate a secure random string)
REVALIDATION_SECRET=your-secure-secret-key-here

# SMTP Configuration (Hostinger)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-email@yourdomain.com
SMTP_PASSWORD=your-email-password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME="Junk Butlers"
TO_EMAIL=your-personal-email@example.com

# Set to 'development' for local testing, 'production' for live site
NODE_ENV=development
